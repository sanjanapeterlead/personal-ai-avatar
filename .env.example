# LLM provider: ollama | gemini
LLM_PROVIDER=gemini

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# Avatar owner (shown in UI and escalation emails)
AVATAR_OWNER_NAME=Your Name
AVATAR_OWNER_EMAIL=your@email.com
AVATAR_OWNER_WHATSAPP=
